---
interface Props {
  class?: string
}

const { class: className } = Astro.props
---

<svg
  class:list={['text-primary', className]}
  viewBox="0 0 200 200"
  xmlns="http://www.w3.org/2000/svg"
  fill="none"
  aria-hidden="true"
>
  <circle cx="100" cy="100" r="80" stroke="currentColor" stroke-width="4" opacity="0.25" />
  <text x="50%" y="54%" text-anchor="middle" font-size="72" font-weight="700" fill="currentColor" dominant-baseline="middle">404</text>
</svg>

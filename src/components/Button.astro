---
interface Props {
  label: string
  href: string
  variant?: 'yellow' | 'orange' | 'primary' | 'outline-primary' | 'outline'
  size?: 'sm' | 'md'
  class?: string
  targetBlank?: boolean
}

const {
  label,
  href,
  variant = 'yellow',
  size = 'md',
  class: className,
  targetBlank = false,
} = Astro.props

const sizeClasses = {
  sm: 'px-3 py-1.5 text-sm',
  md: 'px-6 py-3',
}

// Each variant has a base color and a slightly darker (or tinted) hover color.
const variantClasses = {
  yellow: 'bg-yellow-300 hover:bg-yellow-400 !text-black',
  orange: 'bg-orange-300 hover:bg-orange-400 !text-black',
  primary: 'bg-primary hover:bg-primary-light !text-white',
  'outline-primary': 'border border-primary hover:bg-primary/10 !text-primary',
  outline: 'border border-gray-200 bg-white hover:bg-gray-100 !text-black',
}
---

<a
  href={href}
  target={targetBlank ? '_blank' : undefined}
  rel={targetBlank ? 'noopener noreferrer' : undefined}
  class:list={[
    'inline-block whitespace-nowrap rounded-md font-medium !no-underline !hover:no-underline transition-colors',
    sizeClasses[size],
    variantClasses[variant],
    className,
  ]}
>
  {label}
</a>

---
import BaseLayout from './BaseLayout.astro'

interface Props {
  title: string
  image?: ImageMetadata
}

const { title, image } = Astro.props
---

<BaseLayout title={title} staticHeader image={image}>
  <div class="w-full max-w-6xl px-6 py-16">
    <div class="flex flex-col gap-8 md:flex-row lg:gap-12">
      <slot />
    </div>
    <slot name="after" />
  </div>
</BaseLayout>
